PORT=4000

# 무료 로컬 AI: Ollama (설치: https://ollama.com, 모델 받기: `ollama pull qwen2.5`)
# Ollama가 꺼져 있으면 AI 매핑 생성은 에러를 반환하고, 이상탐지 설명은 규칙 기반 문구로 폴백합니다.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

DATA_DIR=./data

# 이상탐지 민감도: 값이 작을수록 더 민감하게 탐지
ANOMALY_ZSCORE_THRESHOLD=2.5
ANOMALY_MIN_SAMPLES=5
